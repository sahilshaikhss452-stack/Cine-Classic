# Shared Sanity configuration
# Copy to .env.local (Next.js) and .env (sanity-studio) with real values.

SANITY_PROJECT_ID=your_project_id_here
SANITY_DATASET=production

# Server-only write access for booking inquiries and bootstrap scripts
SANITY_WRITE_TOKEN=your_editor_token_here

# Shared secret used by the Sanity webhook calling /api/revalidate?secret=...
SANITY_REVALIDATE_SECRET=your_random_secret_here
