# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these from: https://sanity.io/manage → your project → API → Tokens

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Read token — needed for draft previews / private data (optional)
SANITY_API_TOKEN=your_read_token_here

# Write token — required for booking inquiries to be saved in Sanity CMS
# Generate at: https://sanity.io/manage → project → API → Tokens (Editor permission)
SANITY_WRITE_TOKEN=your_write_token_here
